  },
  "devDependencies": {
    "@plone/components": "workspace:*",
    "@plone/registry": "workspace:*",
    "@plone/scripts": "workspace:*",
    "@plone/types": "workspace:*",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "query-string": "^9.3.1",
    "react-aria": "^3.48.0",
