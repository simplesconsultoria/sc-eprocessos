<?xml version="1.0" encoding="utf-8"?>
<object xmlns:i18n="http://xml.zope.org/namespaces/i18n"
        meta_type="Dexterity FTI"
        name="Legislaturas"
        i18n:domain="sc.eprocessos"
>
  <property name="title"
            i18n:translate=""
  >Legislaturas</property>
  <property name="description"
            i18n:translate=""
  >Facade for legislative terms</property>
  <property name="factory">Legislaturas</property>
  <property name="add_view_expr">string:${folder_url}/++add++Legislaturas</property>
  <property name="link_target" />
  <property name="immediate_view">view</property>
  <property name="global_allow">True</property>
  <property name="filter_content_types">True</property>
  <property name="allowed_content_types" />
  <property name="icon_expr">string:plone-icon-calendar</property>
  <property name="add_permission">sc.eprocessos.AddLegislaturas</property>
  <property name="klass">sc.eprocessos.content.legislaturas.Legislaturas</property>
  <property name="model_source" />
  <property name="model_file" />
  <property name="schema">sc.eprocessos.interfaces.ILegislaturas</property>
  <property name="behaviors">
    <element value="plone.basic" />
    <element value="plone.namefromtitle" />
    <element value="plone.shortname" />
    <element value="plone.excludefromnavigation" />
    <element value="plone.versioning" />
    <element value="volto.blocks" />
  </property>
  <alias from="(Default)"
         to="(dynamic view)"
  />
  <alias from="edit"
         to="@@edit"
  />
  <alias from="sharing"
         to="@@sharing"
  />
  <alias from="view"
         to="(selected layout)"
  />
  <action action_id="view"
          category="object"
          condition_expr=""
          title="View"
          url_expr="string:${object_url}"
          visible="True"
          i18n:attributes="title"
  >
    <permission value="View" />
  </action>
  <action action_id="edit"
          category="object"
          condition_expr=""
          title="Edit"
          url_expr="string:${object_url}/edit"
          visible="True"
          i18n:attributes="title"
  >
    <permission value="Modify portal content" />
  </action>
</object>
